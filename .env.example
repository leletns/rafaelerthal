# ============================================================
# ENVIRONMENT VARIABLES — Clínica Blue Dashboard
# ============================================================

# Token de acesso ao dashboard (login)
DASHBOARD_ACCESS_TOKEN=your_secure_token_here

# Google Apps Script — URL do web app implantado
# O token do script fica aqui (mesma string que TOKEN_SECRETO no Apps Script)
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
APPS_SCRIPT_TOKEN=May@Blue2026

# AmigoClinic API — Bearer token (nunca exposto no front)
AMIGOCLINIC_API_KEY=your_amigoclinic_bearer_token_here

# Anthropic API (assistente IA — servidor apenas)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Next.js
NEXT_PUBLIC_APP_NAME=Mydash Clínica Blue
