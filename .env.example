# ============================================================
# Mydash — Clínica Blue · Variáveis de ambiente
# Copie para .env.local (dev) ou configure no painel do Vercel.
# ============================================================

# Token de acesso ao dashboard (login e proteção das rotas de API)
DASHBOARD_ACCESS_TOKEN=

# Google Sheets via Apps Script (fonte primária de dados)
APPS_SCRIPT_URL=
APPS_SCRIPT_TOKEN=

# Google Gemini — OCR de comprovantes (tier gratuito)
# Gere a chave em https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Opcional: sobrescreve o modelo (padrão: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude — assistente de chat e fallback do OCR
ANTHROPIC_API_KEY=

# AmigoClinic — sincronização de aniversários
AMIGOCLINIC_API_KEY=
