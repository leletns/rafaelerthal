# ============================================================
# ENVIRONMENT VARIABLES — Clínica Blue Dashboard
# ============================================================

# Access token for dashboard login (required in production)
# Set this to any secure random string
DASHBOARD_ACCESS_TOKEN=your_secure_token_here

# Google Apps Script URL (for Google Sheets sync)
# Deploy your Apps Script and paste the web app URL here
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Anthropic API key (for AI assistant)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Next.js (auto-set)
NEXT_PUBLIC_APP_NAME=Mydash Clínica Blue
